# Quantum Drug Discovery - Environment Variables
# Copy this to .env and adjust paths as needed

# Python Virtual Environment
PYTHON_ENV=venv
PYTHONPATH=./src:./

# Logging
LOG_LEVEL=INFO

# Quantum Circuit
QUANTUM_BACKEND=default.qubit
QUANTUM_SHOTS=1000

# Training
DEVICE=cpu
BATCH_SIZE=32
LEARNING_RATE=0.001

# Data
DATA_PATH=./data
CACHE_DATASETS=true

# Output
RESULTS_DIR=./results
CHECKPOINT_DIR=./checkpoints
